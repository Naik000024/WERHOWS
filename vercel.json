{
  "version": 2,
  "builds": [
    {
      "src": "warehouse_config/frontend/package.json",
      "use": "@vercel/static-build",
      "config": { "distDir": "build" }
    },
    {
      "src": "warehouse_config/api/index.py",
      "use": "@vercel/python",
      "config": { "maxLambdaSize": "15mb", "runtime": "python3.12" }
    }
  ],
  "routes": [
    { 
      "src": "/api/(.*)", 
      "dest": "warehouse_config/api/index.py" 
    },
    { 
      "src": "/user/(.*)", 
      "dest": "warehouse_config/api/index.py" 
    },
    { 
      "src": "/admin/(.*)", 
      "dest": "warehouse_config/api/index.py" 
    },
    {
      "src": "/static/(.*)",
      "dest": "warehouse_config/api/index.py"
    },
    {
      "src": "/assets/(.*)",
      "dest": "/assets/$1"
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
