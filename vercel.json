{
  "version": 2,
  "builds": [
    {
      "src": "warehouse_config/frontend/package.json",
      "use": "@vercel/static-build",
      "config": { "distDir": "build" }
    },
    {
      "src": "warehouse_config/api/index.py",
      "use": "@vercel/python",
      "config": { "maxLambdaSize": "15mb", "runtime": "python3.12" }
    }
  ],
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "warehouse_config/api/index.py"
    },
    {
      "source": "/user/(.*)",
      "destination": "warehouse_config/api/index.py"
    },
    {
      "source": "/admin/(.*)",
      "destination": "warehouse_config/api/index.py"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
