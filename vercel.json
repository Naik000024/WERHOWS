{
  "version": 2,
  "builds": [
    {
      "src": "warehouse_config/frontend/package.json",
      "use": "@vercel/static-build",
      "config": { "distDir": "build" }
    },
    {
      "src": "warehouse_config/api/index.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "warehouse_config/api/index.py"
    },
    {
      "src": "/user/(.*)",
      "dest": "warehouse_config/api/index.py"
    },
    {
      "src": "/admin/(.*)",
      "dest": "warehouse_config/api/index.py"
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/(.*)",
      "dest": "warehouse_config/frontend/index.html"
    }
  ]
}
